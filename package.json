{
  "name": "@polterware/polterbase",
  "version": "0.1.2",
  "description": "A global CLI for managing Supabase CLI workflows.",
  "type": "module",
  "bin": {
    "polterbase": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/polterware/polterbase.git"
  },
  "bugs": {
    "url": "https://github.com/polterware/polterbase/issues"
  },
  "homepage": "https://github.com/polterware/polterbase#readme",
  "publishConfig": {
    "access": "public"
  },
  "preferGlobal": true,
  "scripts": {
    "dev": "tsup src/index.ts --watch --format esm --dts",
    "build": "tsup src/index.ts --format esm --clean",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "polterware",
    "polterbase",
    "cli",
    "typescript"
  ],
  "author": "Polterware",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "conf": "^15.1.0",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.3.6",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
